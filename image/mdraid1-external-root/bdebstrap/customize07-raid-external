#!/bin/bash
#
# customize07-raid-external - initramfs configuration for RAID support
# Adds necessary kernel modules for booting from RAID arrays
#
# Parameters:
#   $1 - target root filesystem path
#
# Returns:
#   0 - success
#   1 - configuration error
#

set -eu

# Target build root filesystem path
TARGET_ROOT="$1"
echo "Configuring initramfs for RAID support..."

# Add RAID modules to initramfs
INITRAMFS_MODULES="$TARGET_ROOT/etc/initramfs-tools/modules"
{
    echo "# RAID support modules (added by RAID extension)"
    echo "md_mod"
    echo "raid0"
    echo "raid1"
    echo "raid10"
    echo "raid456"
} >> "$INITRAMFS_MODULES"

echo "RAID modules added to initramfs"
